FROM node:20-alpine

WORKDIR /app

# Install pnpm using npm with Chinese mirror (avoids TLS issues)
RUN npm install -g pnpm@9.12.0 --registry=https://registry.npmmirror.com

# Configure pnpm to use Chinese mirror
RUN pnpm config set registry https://registry.npmmirror.com

COPY package.json pnpm-lock.yaml ./
RUN pnpm install --frozen-lockfile

# Copy source
COPY . .

# Build server
RUN pnpm build

EXPOSE 3000

ENV NODE_ENV=production

CMD ["sh", "-c", "pnpm db:migrate && node dist/index.js"]
