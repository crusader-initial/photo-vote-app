FROM node:20-alpine

WORKDIR /app

# Install dependencies
RUN corepack enable
COPY package.json pnpm-lock.yaml ./
RUN pnpm install --frozen-lockfile

# Copy source
COPY . .

# Build server
RUN pnpm build

EXPOSE 3000

ENV NODE_ENV=production

CMD ["sh", "-c", "pnpm db:migrate && node dist/index.js"]
