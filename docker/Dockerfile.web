FROM node:20-alpine AS builder
WORKDIR /app
RUN corepack enable
COPY package.json pnpm-lock.yaml ./
RUN pnpm install --frozen-lockfile
COPY . .

ARG EXPO_PUBLIC_API_BASE_URL
ARG EXPO_PUBLIC_OAUTH_PORTAL_URL
ARG EXPO_PUBLIC_APP_ID

ENV EXPO_PUBLIC_API_BASE_URL=$EXPO_PUBLIC_API_BASE_URL
ENV EXPO_PUBLIC_OAUTH_PORTAL_URL=$EXPO_PUBLIC_OAUTH_PORTAL_URL
ENV EXPO_PUBLIC_APP_ID=$EXPO_PUBLIC_APP_ID

RUN node -e "const fs=require('fs');const path=require('path');const pkg=require.resolve('react-native-css-interop/package.json');const real=fs.realpathSync(path.dirname(pkg));const dir=path.join(real,'.cache');fs.mkdirSync(dir,{recursive:true});fs.writeFileSync(path.join(dir,'web.css'),'');"
RUN pnpm exec expo export --platform web --output-dir web-dist

FROM nginx:1.27-alpine
COPY docker/nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=builder /app/web-dist /usr/share/nginx/html
EXPOSE 8081
CMD ["nginx", "-g", "daemon off;"]
